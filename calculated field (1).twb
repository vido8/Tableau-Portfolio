      <aliases enabled='yes' />
      <column caption='Delivery Status' datatype='string' name='[Calculation_1377744897302528]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF[Delivery_Time_Min]&lt;30 THEN &quot;Fast&quot;&#13;&#10;Else &quot;Delayed&quot;&#13;&#10;END' />
      </column>
      <column caption='Loss Status' datatype='string' name='[Calculation_1377744903417857]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Profit] &lt; 0 THEN &quot;Loss&quot;&#13;&#10;ELSE &quot;Profit&quot;&#13;&#10;END' />
      </column>
      <column caption='Rank Product' datatype='boolean' name='[Calculation_1377744906473475]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(SUM([Sales])) &lt;=[Parameters].[Parameter 1]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Avg Sales per City' datatype='real' name='[Calculation_1377744910053380]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [City] :AVG([Sales])}' />
      </column>
      <column caption='Avg SalesperProduct' datatype='real' name='[Calculation_1377744911142917]' role='measure' type='quantitative'>
